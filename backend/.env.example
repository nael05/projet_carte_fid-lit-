# ===== DATABASE =====
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=loyalty_saas
PORT=5000

# ===== JWT =====
JWT_SECRET=your_super_secret_key_change_this_in_production

# ===== APPLE WALLET =====
# Configuration pour la génération de passes Apple Wallet
# CERTIFICAT: Obtenir depuis Apple Developer Account (Pass Type ID Certificate)
# Format: PKCS#12 (.p12) ou PEM séparé (cert.pem + key.pem)
APPLE_TEAM_ID=XXXXXXXXXX
APPLE_PASS_TYPE_ID=pass.com.enterprise.loyaltycard
APPLE_CERT_PATH=./certs/apple-wallet-cert.p12
APPLE_CERT_PASSWORD=

# APPLE WWDR (Certificat Apple Worldwide Developer Relations CA)
# Télécharger depuis: https://developer.apple.com/account/
APPLE_WWDR_CERT_PATH=./certs/AppleWWDRCA.cer

# APPLE PUSH NOTIFICATIONS (APNs)
# Clé P8 pour les notifications push (obtenir depuis Apple Developer)
APPLE_APN_KEY_PATH=./certs/AuthKey_XXXXXXXXXX.p8
APPLE_APN_KEY_ID=XXXXXXXXXX
APPLE_APN_TEAM_ID=XXXXXXXXXX
# Environment: production ou development
APPLE_APN_ENVIRONMENT=development

# ===== APPLE WALLET WEB SERVICE =====
# URL où Apple Wallet enverra les requêtes de mise à jour
# DOIT être accessible et en HTTPS
APPLE_WALLET_WEBSERVICE_URL=https://your-domain.com/api/wallet
APPLE_WALLET_IGNORE_EXPIRY=false

# ===== GOOGLE WALLET =====
GOOGLE_WALLET_KEY_PATH=./certs/google-wallet-key.json

# ===== FRONTEND URL =====
FRONTEND_URL=http://localhost:3000

# ===== FIREBASE / FCM (Notifications Android Google Wallet) =====
# Utilise le même fichier de clés que Google Wallet (GOOGLE_WALLET_KEY_PATH)
# Activer Firebase Cloud Messaging dans la Google Cloud Console du projet

