# ===== DATABASE =====
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=loyalty_saas
PORT=5000

# ===== JWT =====
JWT_SECRET=your_super_secret_key_change_this_in_production

# ===== APPLE WALLET =====
# Configuration pour la génération de passes Apple Wallet
# Certificat source: certificat_final.p12 (Pass Type ID Certificate signé par Apple)
# Placer le certificat en: backend/certs/apple-wallet-cert.p12
APPLE_TEAM_ID=8QYMJ4RJ55
APPLE_PASS_TYPE_ID=pass.com.fidelyz.apple.passkit
APPLE_CERT_PATH=./certs/apple-wallet-cert.p12
# APPLE_CERT_PASSWORD reste vide si le certificat n'a pas de mot de passe (recommandé)
APPLE_CERT_PASSWORD=

# ===== GOOGLE WALLET =====
# Chemin vers le fichier JSON de clé Google Service Account
# Place ton fichier google-wallet-key.json dans ./certs/
GOOGLE_WALLET_KEY_PATH=./certs/google-wallet-key.json

# ===== FRONTEND URL (pour Google Wallet) =====
FRONTEND_URL=http://localhost:3000
