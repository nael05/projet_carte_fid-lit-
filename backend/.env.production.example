# ⚠️ CONFIGURATION PRODUCTION - À compléter avec vos valeurs réelles
# ⚠️ Ne JAMAIS committer ce fichier avec les secrets réels

NODE_ENV=production
PORT=5000

# ===== DATABASE =====
DB_HOST=your_prod_db_host
DB_PORT=3306
DB_NAME=loyalty_db
DB_USER=prod_db_user
DB_PASSWORD=your_secure_db_password

# ===== SECURITY =====
JWT_SECRET=your_super_strong_random_jwt_secret_min_32_chars
ALLOWED_ORIGINS=https://app.example.com,https://www.example.com
CORS_CREDENTIALS=true

# ===== FRONTEND =====
FRONTEND_URL=https://app.example.com

# ===== GOOGLE WALLET =====
GOOGLE_WALLET_ISSUER_ID=your_issuer_id
GOOGLE_WALLET_CREDENTIALS={"type":"service_account",...}

# ===== APPLE WALLET =====
APPLE_CERT_PASSWORD=your_apple_cert_password

# ===== LOGGING =====
LOG_LEVEL=info

# ===== SESSION =====
SESSION_SECRET=your_session_secret_min_32_chars
